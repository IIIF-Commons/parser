{
  "@context": "http://iiif.io/api/presentation/4/context.json",
  "id": "https://example.org/iiif/manifest/aggregates",
  "type": "Manifest",
  "label": {
    "en": ["Gold annotation aggregate manifest"]
  },
  "items": [
    {
